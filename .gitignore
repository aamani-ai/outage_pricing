# TypeScript incremental build cache (machine-local)
*.tsbuildinfo

# Local external reference clone. Keep the project source of truth separate.
docs/extra/outage_modeling_us/
docs/extra/hazard_modeling/

# Symlinks to sibling projects (machine-local refs — GCP patterns, examples, etc.)
refs/

# Per-county event JSONs — derived from events.parquet, hosted in GCS (app/county_events/)
price_engine/data/county_events/
# Per-county-per-year raw 15-min traces — derived from raw EAGLE-I, hosted in GCS (app/county_traces/)
price_engine/data/county_traces/

# Stray local files (agent memory belongs in ~/.claude; scratch scripts are throwaway)
memory/
scratchpad_profile.py
scratchpad_*.py

# Dashboard-rebuild reference symlinks (renewablesinfo web/principles, old dashboard).
# Reference, NOT constraint — local-only pointers; never committed (repo is public).
docs/extra/references/

# Reproducible local EAGLE-I inputs and generated price-engine artifacts.
price_engine/data/raw/
price_engine/data/*.parquet
price_engine/data/*.json
price_engine/data/raw/*.part
price_engine/filtration/county_tiers.csv
price_engine/pricing/county_premiums.csv
price_engine/pricing/county_drilldown.json
price_engine/pricing/event_evidence/
price_engine/catalogs/*/data/*.parquet
price_engine/catalogs/*/data/*.json
price_engine/catalogs/*/filtration/*.csv
price_engine/catalogs/*/pricing/*.csv
price_engine/catalogs/*/pricing/*.json
!price_engine/catalogs/*/pricing/county_predictability.json
!price_engine/catalogs/*/pricing/county_lambda_shadow.json
price_engine/catalogs/*/pricing/event_evidence/

# Curated outage data local source downloads and generated artifacts.
curated_outage_data/data/raw/**
curated_outage_data/data/interim/**
curated_outage_data/data/processed/**
curated_outage_data/outputs/**
!curated_outage_data/data/README.md
!curated_outage_data/outputs/README.md

# NDA-scoped vendor evaluation materials — local-only, never push to a public
# (or any non-NDA-protected) remote. Includes the PowerOutage.US trial folder
# (vendor PDFs, raw API responses, derived analysis), the zipped archive, and
# the outage_data exports folder that holds vendor-exported spreadsheets.
docs/extra/poweroutage_us/
docs/extra/poweroutage_us.zip
docs/extra/outage_data/

# Claude Code session state (local working memory; not part of project source).
.claude/

# Mapbox public token, injected at runtime via window.__MAPBOX_TOKEN__.
# Deploy: written by CI from the MAPBOX_TOKEN Actions secret. Local dev: create
# this file by hand. Never committed (repo is public; push protection blocks it).
price_engine/dashboard/config.local.js

# local dev scratch (notebook builders, throwaway analysis)
scratchpad/

# New dashboard app (P1+): deps, build output, local secrets — source is tracked, these are not.
web/node_modules/
web/.next/
web/dist/
web/coverage/
web/config.local.js
web/.env*.local
